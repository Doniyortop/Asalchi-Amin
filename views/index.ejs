<section class="page-header">
  <div>
    <h1><%= t('home.title') %></h1>
    <p class="subtitle"><%= t('home.subtitle') %></p>
  </div>
  <div class="highlight-card">
    <h2><%= t('home.deliveryTitle') %></h2>
    <ul>
      <% t('home.deliveryItems').forEach(function (line) { %>
        <li><%= line %></li>
      <% }) %>
    </ul>
  </div>
</section>

<section class="catalog-filters">
  <form action="/" method="GET" class="search-form">
    <div class="search-input-group">
      <input 
        type="text" 
        name="search" 
        placeholder="Поиск мёда (например, липовый...)" 
        value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
        class="search-input"
      >
      <button type="submit" class="btn-search">🔍</button>
    </div>
  </form>
</section>

<section class="products-grid">
  <% if (!products.length) { %>
    <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
      <div class="empty-results">
        <p>По запросу «<strong><%= searchQuery %></strong>» ничего не найдено.</p>
        <a href="/" class="btn-ghost">Сбросить поиск</a>
      </div>
    <% } else { %>
      <p><%= t('home.emptyProducts') %></p>
    <% } %>
  <% } %>

  <% products.forEach(product => { %>
    <article class="product-card">
      <div class="product-image">
        <% if (product.image) { %>
          <img src="<%= product.image %>" alt="<%= product.name %>" />
        <% } else { %>
          <div class="placeholder-image">Мёд</div>
        <% } %>
      </div>
      <div class="product-body">
        <h3><%= product.name %></h3>
        <% if (product.description) { %>
          <p class="product-description"><%= product.description %></p>
        <% } %>
        
        <!-- Рейтинг и отзывы -->
        <% 
        const productReviews = reviews.filter(r => r.productId === product.id && r.approved);
        const avgRating = productReviews.length > 0 ? 
          productReviews.reduce((sum, r) => sum + r.rating, 0) / productReviews.length : 0;
        %>
        <% if (productReviews.length > 0) { %>
          <div class="product-rating">
            <div class="stars">
              <% for (let i = 1; i <= 5; i++) { %>
                <% if (i <= Math.round(avgRating)) { %>
                  <span class="star filled">★</span>
                <% } else { %>
                  <span class="star">☆</span>
                <% } %>
              <% } %>
            </div>
            <span class="rating-text">
              <%= avgRating.toFixed(1) %> (<%= productReviews.length %> всего отзывов)
            </span>
          </div>
        <% } %>
        
        <div class="product-footer">
          <div class="product-price">
            <span class="price-value"><%= product.price.toLocaleString('ru-RU') %> сум</span>
            <% if (product.unit) { %>
              <span class="price-unit"><%= product.unit %></span>
            <% } %>
          </div>
          <form action="/cart/add/<%= product.id %>" method="POST" class="add-to-cart-form">
            <input
              type="number"
              name="quantity"
              min="1"
              value="1"
            />
            <button type="submit" class="btn-small"><%= t('home.addToCart') %></button>
          </form>
        </div>
      </div>
    </article>
  <% }) %>
</section>

