<section class="page-header">
  <div>
    <h1>Вход в аккаунт</h1>
    <p class="subtitle">Войдите по телефону или email</p>
  </div>
</section>

<section class="card form-card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/login" method="POST" class="form">
    <div class="form-group">
      <label for="login">Телефон или Email *</label>
      <input
        type="text"
        id="login"
        name="login"
        placeholder="+998... или email@example.com"
        value="<%= values.login || '' %>"
        required
      />
      <small class="field-hint">Введите номер телефона или email</small>
    </div>

    <div class="form-group">
      <label for="password">Пароль *</label>
      <input
        type="password"
        id="password"
        name="password"
        required
      />
    </div>

    <button type="submit" class="btn full-width">Войти</button>

    <p class="form-footer">
      Нет аккаунта?
      <a href="/register">Зарегистрироваться</a>
    </p>
  </form>
</section>

