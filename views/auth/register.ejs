<section class="page-header">
  <div>
    <h1>Регистрация</h1>
    <p class="subtitle">Создайте аккаунт для быстрых заказов</p>
  </div>
</section>

<section class="card form-card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form action="/register" method="POST" class="form">
    <div class="form-group">
      <label for="name">Имя *</label>
      <input
        type="text"
        id="name"
        name="name"
        value="<%= values.name || '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="phone">Телефон *</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+998..."
        value="<%= values.phone || '' %>"
        required
      />
      <small class="field-hint">Основной способ связи для заказов</small>
    </div>

    <div class="form-group">
      <label for="email">Email (необязательно)</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="email@example.com"
        value="<%= values.email || '' %>"
      />
      <small class="field-hint">Для получения акций и уведомлений</small>
    </div>

    <div class="form-group">
      <label for="password">Пароль *</label>
      <input
        type="password"
        id="password"
        name="password"
        minlength="6"
        required
      />
      <small class="field-hint">Минимум 6 символов</small>
    </div>

    <button type="submit" class="btn full-width">Зарегистрироваться</button>

    <p class="form-footer">
      Уже есть аккаунт?
      <a href="/login">Войти</a>
    </p>
  </form>
</section>

