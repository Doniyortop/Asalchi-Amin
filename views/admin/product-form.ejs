<section class="page-header">
  <div>
    <h1><%= product ? 'Редактирование товара' : 'Новый товар' %></h1>
    <p class="subtitle">
      Укажите основные характеристики товара. Изображение можно загрузить в папку `public/images` и указать путь.
    </p>
  </div>
</section>

<section class="card form-card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form
    action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>"
    method="POST"
    enctype="multipart/form-data"
    class="form"
  >
    <div class="form-group">
      <label for="name">Название</label>
      <input
        type="text"
        id="name"
        name="name"
        value="<%= product ? product.name : '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="description">Описание</label>
      <textarea
        id="description"
        name="description"
        rows="3"
      ><%= product ? product.description : '' %></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="price">Цена, сум</label>
        <input
          type="number"
          id="price"
          name="price"
          min="0"
          step="1000"
          value="<%= product ? product.price : '' %>"
          required
        />
      </div>

      <div class="form-group">
        <label for="unit">Единица (например, «за 1 кг»)</label>
        <input
          type="text"
          id="unit"
          name="unit"
          value="<%= product ? product.unit : '' %>"
        />
      </div>
    </div>

    <div class="form-group">
      <label for="imageFile">Изображение товара</label>
      <% if (product && product.image) { %>
        <div class="field-hint">
          Текущее изображение: <code><%= product.image %></code>
        </div>
      <% } %>
      <input
        type="file"
        id="imageFile"
        name="imageFile"
        accept="image/*"
      />
      <small class="field-hint">
        Выберите файл изображения (JPEG, PNG, WEBP и т.п.). Максимум 5 МБ.
        При сохранении нового файла старый путь будет заменён.
      </small>
    </div>

    <div class="form-group">
      <label class="checkbox">
        <input
          type="checkbox"
          name="isActive"
          value="1"
          <%= !product || product.isActive ? 'checked' : '' %>
        />
        <span>Показывать товар в каталоге</span>
      </label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">
        <%= product ? 'Сохранить изменения' : 'Создать товар' %>
      </button>
      <a href="/admin" class="btn-ghost">Отмена</a>
    </div>
  </form>
</section>

